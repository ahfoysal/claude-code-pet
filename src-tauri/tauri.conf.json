{
  "$schema": "https://raw.githubusercontent.com/nicedozie4u/tauri-schema/v2/schema.json",
  "productName": "Claude Code Pet",
  "version": "1.0.0",
  "identifier": "com.claudecodepet.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "pet",
        "title": "Claude Code Pet",
        "width": 400,
        "height": 296,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "x": 900,
        "y": 500
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/themes/": "themes/"
    }
  },
  "plugins": {
    "process": {},
    "deep-link": {
      "desktop": {
        "schemes": [
          "claude-code-pet"
        ]
      }
    }
  }
}